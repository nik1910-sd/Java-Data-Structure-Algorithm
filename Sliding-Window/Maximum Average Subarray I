class Solution {
    public double findMaxAverage(int[] nums, int k) {
      int max=Integer.MIN_VALUE;
      int curr=0;
      for(int i=0;i<nums.length;i++){
        curr+=nums[i];
        if(i>=k){
            curr-=nums[i-k];
        }
        if(i>=k-1){
        max=Math.max(curr,max);
        }
      }  
      return max/k;
    }
}
