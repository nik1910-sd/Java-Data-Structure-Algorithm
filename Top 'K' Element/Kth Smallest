class Solution {
    public int kthSmallest(int[] arr, int k) {
        
        PriorityQueue<Integer> pq=new PriorityQueue<>((a,b)-> Integer.compare(b,a));
        
        for(int i=0;i<arr.length;i++){
            pq.offer(arr[i]);
            if(pq.size()>k){
                pq.poll();
            }
        }
        return pq.peek();
    }
}
